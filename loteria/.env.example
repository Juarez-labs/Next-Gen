# --- Supabase ---
# Public anon key + URL — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Service role key — server only. Required for admin DB writes / migrations
# triggered from the app. DO NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Higgsfield AI (Phase 1+) ---
# Card art and Phase 3 photo-to-character generation.
HIGGSFIELD_API_KEY=""
HIGGSFIELD_WORKSPACE_ID=""

# --- Anthropic (Claude) ---
# Used for the 54-card concept generator from a theme.
ANTHROPIC_API_KEY=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
